{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/lib/index.ts"],
  "out": "docs/api",
  "name": "flow2code API Reference",
  "readme": "none",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "categorizeByGroup": true,
  "sort": ["source-order"],
  "navigationLinks": {
    "GitHub": "https://github.com/timo9378/flow2code",
    "npm": "https://www.npmjs.com/package/flow2code"
  },
  "plugin": ["typedoc-plugin-markdown"],
  "githubPages": false,
  "tsconfig": "tsconfig.typedoc.json"
}
