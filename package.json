{
  "name": "flow2code",
  "version": "0.1.0",
  "description": "Visual AST Compiler: Flow-based visual editor that compiles to native TypeScript code",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:server": "tsx src/server/index.ts",
    "build": "pnpm build:ui && pnpm build:cli",
    "build:ui": "next build",
    "build:cli": "tsup",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "compile": "node --loader ts-node/esm src/cli/index.ts compile",
    "watch": "node --loader ts-node/esm src/cli/index.ts watch",
    "prepublishOnly": "pnpm build"
  },
  "bin": {
    "flow2code": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/server.js"
    },
    "./compiler": {
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "out",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "flow",
    "visual-programming",
    "ast",
    "compiler",
    "typescript",
    "next.js"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "ts-morph": "^27.0.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "eslint": "^10.0.2",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zustand": "^5.0.11"
  }
}
