{
  "version": "1.0.0",
  "meta": {
    "name": "Auth Check with If/Else",
    "description": "POST /api/login → Validate credentials with If/Else branching, return success or 401.",
    "createdAt": "2026-02-27T00:00:00Z",
    "updatedAt": "2026-02-27T00:00:00Z"
  },
  "nodes": [
    {
      "id": "trigger_login",
      "nodeType": "http_webhook",
      "category": "trigger",
      "label": "POST /api/login",
      "params": {
        "method": "POST",
        "routePath": "/api/login",
        "parseBody": true
      },
      "inputs": [],
      "outputs": [
        { "id": "request", "label": "Request", "dataType": "object" },
        { "id": "body", "label": "Body", "dataType": "object" }
      ]
    },
    {
      "id": "check_credentials",
      "nodeType": "if_else",
      "category": "logic",
      "label": "Valid Credentials?",
      "params": {
        "condition": "flowState['trigger_login'].body.email === 'admin@example.com' && flowState['trigger_login'].body.password === 'secret'"
      },
      "inputs": [
        { "id": "data", "label": "Data", "dataType": "any", "required": true }
      ],
      "outputs": [
        { "id": "true", "label": "Valid", "dataType": "any" },
        { "id": "false", "label": "Invalid", "dataType": "any" }
      ]
    },
    {
      "id": "response_ok",
      "nodeType": "return_response",
      "category": "output",
      "label": "Login Success",
      "params": {
        "statusCode": 200,
        "bodyExpression": "{ token: \"jwt-token-here\", message: \"Login successful\" }"
      },
      "inputs": [
        { "id": "data", "label": "Data", "dataType": "any", "required": true }
      ],
      "outputs": []
    },
    {
      "id": "response_401",
      "nodeType": "return_response",
      "category": "output",
      "label": "Unauthorized",
      "params": {
        "statusCode": 401,
        "bodyExpression": "{ error: \"Invalid credentials\" }"
      },
      "inputs": [
        { "id": "data", "label": "Data", "dataType": "any", "required": true }
      ],
      "outputs": []
    }
  ],
  "edges": [
    {
      "id": "e_trigger_check",
      "sourceNodeId": "trigger_login",
      "sourcePortId": "body",
      "targetNodeId": "check_credentials",
      "targetPortId": "data"
    },
    {
      "id": "e_check_ok",
      "sourceNodeId": "check_credentials",
      "sourcePortId": "true",
      "targetNodeId": "response_ok",
      "targetPortId": "data"
    },
    {
      "id": "e_check_fail",
      "sourceNodeId": "check_credentials",
      "sourcePortId": "false",
      "targetNodeId": "response_401",
      "targetPortId": "data"
    }
  ]
}
