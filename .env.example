# Flow2Code 環境變數
# 複製此檔案為 .env.local 並填入實際值

# AI 生成功能（P0: Prompt-to-Graph）
# 支援 OpenAI 相容 API（如 OpenAI、OpenRouter、本地 LLM）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 應用程式設定
# PORT=3000

# --- 以下由編譯器自動偵測的環境變數 ---
# （當你的流程中使用 ${VAR_NAME} 語法時會出現在這裡）
# API_BASE_URL=
# API_KEY=
# DB_PASSWORD=
